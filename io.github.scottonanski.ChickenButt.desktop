[Desktop Entry]
Type=Application
# Desktop Entry Specification version this file conforms to — not
# ChickenButt's own release version (see release_info.VERSION for that).
Version=1.0
Name=ChickenButt
Comment=Local Ollama chat for GNOME
Exec=@REPO_DIR@/run.sh
Icon=chickenbutt
Terminal=false
Categories=Utility;Network;Chat;
StartupNotify=true
# Must match Gio.Application application_id (release_info.APP_ID) so the
# dock uses this icon/name.
StartupWMClass=io.github.scottonanski.ChickenButt
X-GNOME-Autostart-enabled=false
DBusActivatable=false
