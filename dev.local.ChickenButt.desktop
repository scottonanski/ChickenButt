[Desktop Entry]
Type=Application
Version=1.0
Name=ChickenButt
Comment=Local Ollama chat for GNOME
Exec=@REPO_DIR@/run.sh
Icon=chickenbutt
Terminal=false
Categories=Utility;Network;Chat;
StartupNotify=true
# Must match Gio.Application application_id so the dock uses this icon/name
StartupWMClass=dev.local.ChickenButt
X-GNOME-Autostart-enabled=false
DBusActivatable=false
